{
  "entryFile": "src/index.ts",
  "noImplicitAdditionalProperties": "throw-on-extras",
  "controllerPathGlobs": ["src/Controllers/*Controller.ts"],
  "spec": {
    "outputDirectory": "build",
    "specVersion": 3,
    "servers": [
      { "url": "https://askorg.vercel.app" }
    ]
  },
  "routes": {
    "routesDir": "src",
    "iocModule": "src/ioc"
  }
}